{
  "name": "Expense Tracker PWA",
  "short_name": "Expense Tracker",
  "description": "A modern Progressive Web App for tracking income and expenses with offline support",
  "start_url": "./",
  "orientation": "portrait",
  "icons": [
    {
      "src": "./assets/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "./assets/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "Add Income Widget",
      "short_name": "+ Income",
      "description": "Directly record a new income source",
      "url": "./?page=addTransaction&type=income",
      "icons": [
        {
          "src": "./assets/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Add Expense Widget",
      "short_name": "- Expense",
      "description": "Directly record a new expense source",
      "url": "./?page=addTransaction&type=expense",
      "icons": [
        {
          "src": "./assets/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "View History Widget",
      "short_name": "History",
      "description": "View all historical transactions",
      "url": "./?page=history",
      "icons": [
        {
          "src": "./assets/icon-192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "display": "standalone",
  "theme_color": "#4F46E5",
  "background_color": "#FFFFFF",
  "categories": ["finance", "productivity"],
  "screenshots": [
    {
      "src": "./assets/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "narrow"
    }
  ],
  "share_target": {
    "action": "./share",
    "method": "POST",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "file_handlers": [
    {
      "action": "./open-csv",
      "accept": {
        "text/csv": [".csv"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+expenses",
      "url": "./handle-protocol?url=%s"
    }
  ]
}
