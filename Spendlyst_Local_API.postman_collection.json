    {
      "name": "Transactions (REST)",
      "item": [
        {
          "name": "Get Transactions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/transactions?userId={{userId}}",
