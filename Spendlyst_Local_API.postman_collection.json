              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"transaction\": {\n    \"id\": \"tx-test-123\",\n    \"date\": \"2026-07-10\",\n    \"type\": \"expense\",\n    \"category\": \"Food\",\n    \"amount\": 500.00,\n    \"description\": \"Dinner out (with tip)\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/transactions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "transactions"
              ]
            },
            "description": "Updates an existing transaction owned by the user."
