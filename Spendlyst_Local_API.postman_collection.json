          "response": []
        },
        {
          "name": "Delete Transaction",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/transactions?id=tx-test-123&userId={{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "transactions"
              ],
              "query": [
                {
                  "key": "id",
                  "value": "tx-test-123"
                },
                {
                  "key": "userId",
                  "value": "{{userId}}"
                }
              ]
            },
            "description": "Deletes a specific transaction owned by the user."
          },
          "response": []
        }
      ]
